# ML Volatility Forecasting - Environment Variables

# Model Configuration
MODEL_TYPE=xgboost          # rf, gb, xgboost
LOOKBACK_PERIOD=20
TARGET_HORIZON=1
TEST_SIZE=0.2

# Data Source (optional - for real market data integration)
DATA_SOURCE=synthetic       # synthetic, csv, api
DATA_PATH=./data/prices.csv

# Output
MODEL_OUTPUT_PATH=./models/
LOG_LEVEL=INFO
